#!/usr/bin/env python3
"""
Upload siti_contaminati_map.html to GitHub as index.html
Run this from Terminal: python3 upload_to_github.py
"""
import base64, json, urllib.request, urllib.error, os, getpass

REPO   = "gybe777/siti-contaminati-campania"
FILE   = os.path.join(os.path.dirname(__file__), "siti_contaminati_map.html")

print("=" * 56)
print("  Wasted Ecologies → GitHub Pages uploader")
print("=" * 56)
print()
print("You need a GitHub Personal Access Token (PAT).")
print("Create one at: https://github.com/settings/tokens")
print("  → Generate new token (classic)")
print("  → Tick 'repo' scope → copy the token")
print()
token = getpass.getpass("Paste your GitHub token (hidden): ").strip()

if not token:
    print("No token provided. Exiting.")
    exit(1)

print()
print(f"Reading {os.path.basename(FILE)} …")
with open(FILE, "rb") as f:
    content_b64 = base64.b64encode(f.read()).decode()

payload = json.dumps({
    "message": "Add Wasted Ecologies contaminated sites map",
    "content": content_b64
}).encode()

url = f"https://api.github.com/repos/{REPO}/contents/index.html"
req = urllib.request.Request(
    url,
    data    = payload,
    method  = "PUT",
    headers = {
        "Authorization": f"token {token}",
        "Accept":        "application/vnd.github+json",
        "Content-Type":  "application/json",
        "User-Agent":    "WastedEcologies-Uploader/1.0"
    }
)

print(f"Uploading to github.com/{REPO} …")
try:
    with urllib.request.urlopen(req) as resp:
        data = json.loads(resp.read())
        sha  = data.get("content", {}).get("sha", "?")[:7]
        html = data.get("content", {}).get("html_url", "")
        print(f"✓ File committed  (sha {sha})")
        print(f"  {html}")
except urllib.error.HTTPError as e:
    body = e.read().decode()
    print(f"✗ HTTP {e.code}: {body[:300]}")
    exit(1)

print()
print("Now enable GitHub Pages:")
pages_payload = json.dumps({
    "source": {"branch": "main", "path": "/"}
}).encode()
pages_req = urllib.request.Request(
    f"https://api.github.com/repos/{REPO}/pages",
    data    = pages_payload,
    method  = "POST",
    headers = {
        "Authorization": f"token {token}",
        "Accept":        "application/vnd.github+json",
        "Content-Type":  "application/json",
        "User-Agent":    "WastedEcologies-Uploader/1.0"
    }
)
try:
    with urllib.request.urlopen(pages_req) as resp:
        pdata = json.loads(resp.read())
        live  = pdata.get("html_url", f"https://gybe777.github.io/{REPO.split('/')[1]}/")
        print(f"✓ GitHub Pages enabled")
        print()
        print("=" * 56)
        print("  Your map will be live in ~60 seconds at:")
        print(f"  {live}")
        print("=" * 56)
except urllib.error.HTTPError as e:
    body = e.read().decode()
    if e.code == 409:
        print("  (Pages already enabled — no action needed)")
        print()
        print("  Your map will be live at:")
        print(f"  https://gybe777.github.io/siti-contaminati-campania/")
    else:
        print(f"  Pages setup note: HTTP {e.code} — {body[:200]}")
        print("  Enable manually: Settings → Pages → Branch: main → Save")
